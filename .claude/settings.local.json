{
  "permissions": {
    "allow": [
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(npm init -y)",
      "PowerShell(npm install @capacitor/core @capacitor/cli @capacitor/ios)",
      "PowerShell(Test-Path .\\\\node_modules; Test-Path $HOME\\\\package.json; Test-Path $HOME\\\\node_modules)",
      "PowerShell(New-Item -ItemType Directory -Force www)",
      "PowerShell(Copy-Item index.html www\\\\index.html)",
      "PowerShell(Invoke-WebRequest -Uri \"https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.js\" -OutFile \"www\\\\gif.js\")",
      "PowerShell(Invoke-WebRequest -Uri \"https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.worker.js\" -OutFile \"www\\\\gif.worker.js\")",
      "PowerShell(npm install @capacitor/filesystem @capacitor/share)",
      "PowerShell(curl.exe -sL -o www\\\\gif.js \"https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.js\")",
      "PowerShell(curl.exe -sL -o www\\\\gif.worker.js \"https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.worker.js\")",
      "PowerShell([Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -UseBasicParsing -Uri \"https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.js\" -OutFile \"www\\\\gif.js\"; Invoke-WebRequest -UseBasicParsing -Uri \"https://cdnjs.cloudflare.com/ajax/libs/gif.js/0.2.0/gif.worker.js\" -OutFile \"www\\\\gif.worker.js\"; ls www | Select-Object Name, Length)",
      "PowerShell(npx cap add ios)",
      "PowerShell(npm install gif.js@0.2.0)",
      "PowerShell(Copy-Item node_modules\\\\gif.js\\\\dist\\\\gif.js www\\\\gif.js)",
      "PowerShell(Copy-Item node_modules\\\\gif.js\\\\dist\\\\gif.worker.js www\\\\gif.worker.js)",
      "PowerShell(npx cap sync ios)",
      "PowerShell(powershell -ExecutionPolicy Bypass -File .\\\\make-icon.ps1)",
      "PowerShell(npx @capacitor/assets generate --ios)",
      "PowerShell(Get-NetTCPConnection -LocalPort 8123 -State Listen -ErrorAction SilentlyContinue)",
      "PowerShell(Start-Sleep -Seconds 5; Get-NetTCPConnection -LocalPort 8123 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1 LocalAddress, OwningProcess; try { \\(Invoke-WebRequest -UseBasicParsing -Uri \"http://127.0.0.1:8123\" -TimeoutSec 5\\).StatusCode } catch { \"fetch failed: $\\($_.Exception.Message\\)\" })",
      "PowerShell(npm install pretendard)",
      "PowerShell(New-Item -ItemType Directory -Force www\\\\fonts)",
      "PowerShell(Copy-Item node_modules\\\\pretendard\\\\dist\\\\web\\\\variable\\\\woff2\\\\PretendardVariable.woff2 www\\\\fonts\\\\)",
      "Bash(git config *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit -m '도트매트릭스 LED 패널 iOS 앱 초기 커밋 *)",
      "Bash(gh repo *)",
      "Bash(git commit -m 'Update Claude Code settings *)"
    ]
  }
}
